{
	"name": "suhba-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && vite build",
		"check:watch": "vite build --watch",
		"backend": "cd server && poetry run python app.py",
		"backend:dev": "cd server && poetry run python -m uvicorn app:app --reload --host 0.0.0.0 --port 3005",
		"full:dev": "concurrently \"pnpm dev\" \"pnpm backend:dev\"",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"autoprefixer": "^10.4.21",
		"concurrently": "^9.1.0",
		"drizzle-kit": "^0.28.1",
		"postcss": "^8.5.6",
		"svelte": "^5.0.0",
		"tailwindcss": "^4.1.10",
		"vite": "^6.2.6"
	},
	"dependencies": {
		"@sveltejs/adapter-static": "^3.0.8",
		"@tailwindcss/postcss": "^4.1.10",
		"lucide-svelte": "^0.522.0",
		"drizzle-orm": "^0.36.4",
		"better-sqlite3": "^11.5.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"esbuild"
		]
	}
}
